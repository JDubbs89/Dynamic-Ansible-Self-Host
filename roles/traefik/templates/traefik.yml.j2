global:
  checkNewVersion: true
  sendAnonymousUsage: false

api:
  dashboard: true
  insecure: false

log:
  level: INFO

entryPoints:
  web:
    address: ":80"

  web-secure:
    address: ":443"
    http:
      tls: {}

providers:
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false
    network: traefik
  file:
    filename: /etc/traefik/dynamic.yml
    watch: true
# Note: ACME certificate resolvers removed from static config to avoid
# configuration mismatch and network timeouts during setup. If you want
# Traefik to obtain Let's Encrypt certificates, re-add a properly
# structured ACME/tls configuration here and ensure outbound connectivity
# to the ACME server.